{
    "name": "@senoldogann/code-companion",
    "version": "0.1.2",
    "type": "module",
    "bin": {
        "code-companion": "bin/copilot-mobile.mjs"
    },
    "files": [
        "bin/copilot-mobile.mjs",
        "bin/copilot-mobile-daemon.mjs",
        "bin/lib",
        "dist/desktop",
        "apps/bridge-server/dist",
        "packages/shared/dist",
        "README.md",
        "docs/cloudflare-relay.md",
        "docs/desktop-companion.md",
        "docs/relay-deployment.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "code-companion": "node ./bin/copilot-mobile.mjs",
        "copilot-mobile": "node ./bin/copilot-mobile.mjs",
        "login": "node ./bin/copilot-mobile.mjs login",
        "doctor": "node ./bin/copilot-mobile.mjs doctor",
        "dev:bridge": "node ./bin/dev-bridge-direct.mjs",
        "dev:bridge:direct": "node ./bin/dev-bridge-direct.mjs",
        "dev:companion:local": "node ./bin/dev-companion-local.mjs",
        "dev:companion:macos": "swift run --package-path apps/macos-companion",
        "dev:relay:cloudflare": "pnpm --filter @copilot-mobile/cloudflare-relay dev",
        "dev:relay": "pnpm --filter @copilot-mobile/relay-server dev",
        "dev:mobile": "node ./scripts/dev-mobile.mjs",
        "build:bridge": "pnpm --filter bridge-server build",
        "build:companion:macos": "swift build --package-path apps/macos-companion",
        "build:shared": "pnpm --filter @copilot-mobile/shared build",
        "build:desktop": "node ./scripts/build-desktop-runtime.mjs",
        "deploy:relay:cloudflare": "pnpm --filter @copilot-mobile/cloudflare-relay deploy",
        "bridge:up": "node ./bin/copilot-mobile.mjs up",
        "bridge:status": "node ./bin/copilot-mobile.mjs status",
        "bridge:doctor": "node ./bin/copilot-mobile.mjs doctor",
        "bridge:qr": "node ./bin/copilot-mobile.mjs qr",
        "bridge:dashboard": "node ./bin/copilot-mobile.mjs dashboard",
        "bridge:down": "node ./bin/copilot-mobile.mjs down",
        "prepack": "pnpm build:shared && pnpm build:bridge && pnpm build:desktop",
        "test": "pnpm --filter bridge-server test",
        "test:bridge": "pnpm --filter bridge-server test",
        "test:mobile": "pnpm --filter @copilot-mobile/mobile test",
        "typecheck": "pnpm -r typecheck",
        "clean": "pnpm -r clean"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "dependencies": {
        "@github/copilot": "^1.0.35",
        "@github/copilot-sdk": "0.2.2",
        "jsonwebtoken": "9.0.2",
        "qrcode": "1.5.4",
        "ws": "8.18.2",
        "zod": "3.24.4"
    },
    "devDependencies": {
        "esbuild": "^0.25.11",
        "uuid": "14.0.0"
    },
    "pnpm": {
        "overrides": {
            "@tootallnate/once": "3.0.1",
            "uuid": "14.0.0"
        }
    }
}

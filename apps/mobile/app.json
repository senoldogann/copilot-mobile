{
  "expo": {
    "name": "Code Companion",
    "owner": "senoldogan33",
    "slug": "code-companion",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "code-companion",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#161918"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.senoldogan.codecompanion",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required to scan the QR code shown by your Mac companion",
        "NSLocalNetworkUsageDescription": "Local network access helps your iPhone discover and connect to your Mac companion during setup",
        "NSBonjourServices": [
          "_expo._tcp",
          "_react-native._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#161918"
      },
      "package": "dev.senoldogan.codecompanion",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "33e68d9a-4ae3-47b2-b130-04b0c57ed91e"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access is required to scan the QR code shown by your Mac companion"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Photo library access is required to attach images to your chat",
          "cameraPermission": "Camera access is required to capture images for your chat",
          "microphonePermission": false
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#74D6B3",
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ]
  }
}

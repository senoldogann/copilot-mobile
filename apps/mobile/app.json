{
    "expo": {
        "name": "Copilot Mobile",
        "slug": "copilot-mobile",
        "version": "0.1.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "automatic",
        "scheme": "copilot-mobile",
        "splash": {
            "backgroundColor": "#1e1e1e"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "dev.senoldogan.copilot-mobile",
            "infoPlist": {
                "NSCameraUsageDescription": "Camera is required to connect to the bridge server via QR code",
                "NSLocalNetworkUsageDescription": "Local network access is required to connect to your Copilot Bridge running on your computer",
                "NSAppTransportSecurity": {
                    "NSAllowsLocalNetworking": true
                }
            }
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#1e1e1e"
            },
            "package": "dev.senoldogan.copilotmobile",
            "usesCleartextTraffic": true,
            "permissions": [
                "android.permission.CAMERA"
            ]
        },
        "plugins": [
            "expo-router",
            [
                "expo-camera",
                {
                    "cameraPermission": "Camera permission is required for QR code scanning"
                }
            ],
            "expo-secure-store",
            [
                "expo-notifications",
                {
                    "color": "#161918"
                }
            ]
        ]
    }
}

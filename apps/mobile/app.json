{
  "expo": {
    "name": "Copilot Mobile",
    "slug": "copilot-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "copilot-mobile",
    "splash": {
      "backgroundColor": "#1e1e1e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.senoldogan.copilot-mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required to scan the QR code shown by your Mac companion",
        "NSLocalNetworkUsageDescription": "Local network access helps your iPhone discover and connect to your Mac companion during setup",
        "NSBonjourServices": [
          "_expo._tcp",
          "_react-native._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#1e1e1e"
            },
            "package": "dev.senoldogan.copilotmobile",
      "permissions": [
                "android.permission.CAMERA"
            ]
        },
        "extra": {
            "eas": {
                "projectId": "1cc7a8e4-d1aa-48e8-90bc-c2ae41893f35"
            }
        },
        "plugins": [
            "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access is required to scan the QR code shown by your Mac companion"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Photo library access is required to attach images to Copilot chats",
          "cameraPermission": "Camera access is required to capture images for Copilot chats",
          "microphonePermission": false
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#161918",
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ]
  }
}

{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "noUncheckedIndexedAccess": true,
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@copilot-mobile/shared": [
                "../../packages/shared/src"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "src/**/*.ts",
        "src/**/*.tsx",
        "app/**/*.ts",
        "app/**/*.tsx"
    ]
}
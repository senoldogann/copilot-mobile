{
  "name": "@copilot-mobile/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client --host lan",
    "start:dev-client:tunnel": "expo start --dev-client --host tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "pod:ios": "bash ./scripts/pod-install-safe.sh",
    "xcode:ios": "open ios/CopilotMobile.xcworkspace",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .expo dist"
  },
  "dependencies": {
    "@copilot-mobile/shared": "workspace:*",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/drawer": "^7.5.0",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "expo": "~54.0.0",
    "expo-blur": "~14.0.1",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.17",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.8",
    "typescript": "~5.9.3"

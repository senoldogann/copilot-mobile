    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "~55.0.15",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.85.2",
    "react-native-gesture-handler": "~2.31.1",
